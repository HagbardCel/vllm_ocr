{
  "$defs": {
    "Alignment": {
      "enum": [
        "left",
        "center",
        "right",
        "justified",
        "unknown"
      ],
      "type": "string"
    },
    "BBox1000": {
      "additionalProperties": false,
      "properties": {
        "left": {
          "maximum": 1000,
          "minimum": 0,
          "type": "integer"
        },
        "top": {
          "maximum": 1000,
          "minimum": 0,
          "type": "integer"
        },
        "right": {
          "maximum": 1000,
          "minimum": 0,
          "type": "integer"
        },
        "bottom": {
          "maximum": 1000,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "left",
        "top",
        "right",
        "bottom"
      ],
      "type": "object"
    },
    "BlockKind": {
      "enum": [
        "text",
        "footnote",
        "figure",
        "separator"
      ],
      "type": "string"
    },
    "ExtractedMetadata": {
      "additionalProperties": false,
      "properties": {
        "subtitle": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "authors": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "language": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object"
    },
    "InlineKind": {
      "enum": [
        "text",
        "footnote_reference"
      ],
      "type": "string"
    },
    "PageType": {
      "enum": [
        "cover",
        "title",
        "copyright",
        "dedication",
        "toc",
        "preface",
        "chapter_opening",
        "body",
        "figure_page",
        "appendix",
        "bibliography",
        "index",
        "blank",
        "other"
      ],
      "type": "string"
    },
    "RelativeSize": {
      "enum": [
        "small",
        "body",
        "large",
        "extra_large"
      ],
      "type": "string"
    },
    "StructureKind": {
      "enum": [
        "part",
        "chapter",
        "section",
        "subsection",
        "preface",
        "appendix",
        "bibliography",
        "index",
        "other"
      ],
      "type": "string"
    },
    "TextRole": {
      "enum": [
        "book_title",
        "subtitle",
        "author",
        "chapter_title",
        "heading",
        "paragraph",
        "blockquote",
        "epigraph",
        "list_item",
        "caption",
        "running_header",
        "running_footer",
        "page_number",
        "other"
      ],
      "type": "string"
    },
    "VlmBlock": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/BlockKind"
        },
        "role": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextRole"
            },
            {
              "type": "null"
            }
          ]
        },
        "segments": {
          "items": {
            "$ref": "#/$defs/VlmInlineSegment"
          },
          "type": "array"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "caption": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "heading_level": {
          "anyOf": [
            {
              "maximum": 6,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "bbox": {
          "anyOf": [
            {
              "$ref": "#/$defs/BBox1000"
            },
            {
              "type": "null"
            }
          ]
        },
        "relative_size": {
          "anyOf": [
            {
              "$ref": "#/$defs/RelativeSize"
            },
            {
              "type": "null"
            }
          ]
        },
        "bold": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "italic": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "alignment": {
          "anyOf": [
            {
              "$ref": "#/$defs/Alignment"
            },
            {
              "type": "null"
            }
          ]
        },
        "continues_previous": {
          "type": "boolean"
        },
        "continues_on_next_page": {
          "type": "boolean"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "VlmInlineSegment": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/InlineKind"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "value"
      ],
      "type": "object"
    },
    "VlmStructuralOpening": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/StructureKind"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "subtitle": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "level": {
          "maximum": 6,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "kind",
        "title",
        "level"
      ],
      "type": "object"
    },
    "VlmTocEntry": {
      "additionalProperties": false,
      "properties": {
        "level": {
          "maximum": 6,
          "minimum": 1,
          "type": "integer"
        },
        "kind": {
          "$ref": "#/$defs/StructureKind"
        },
        "printed_page_label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "title",
        "level",
        "kind"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "page_type": {
      "$ref": "#/$defs/PageType"
    },
    "printed_page_label": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "opening": {
      "anyOf": [
        {
          "$ref": "#/$defs/VlmStructuralOpening"
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExtractedMetadata"
        },
        {
          "type": "null"
        }
      ]
    },
    "toc_entries": {
      "items": {
        "$ref": "#/$defs/VlmTocEntry"
      },
      "type": "array"
    },
    "blocks": {
      "items": {
        "$ref": "#/$defs/VlmBlock"
      },
      "type": "array"
    }
  },
  "required": [
    "page_type"
  ],
  "type": "object"
}
